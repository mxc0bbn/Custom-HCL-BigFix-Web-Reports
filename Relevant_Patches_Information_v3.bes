<?xml version="1.0" encoding="UTF-8"?>
<BES xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="BES.xsd">
	<Analysis>
		<Title>Relevant Patches Information v3</Title>
		<Description><![CDATA[<P>This analysis counts the number of relevant Fixlets in the Patches sites for the following operating systems:</P>
<UL>
<LI>Windows (all supported versions) 
<LI>RHEL&nbsp; 8/9/10 
<LI>Ubuntu 2204/2404/2604</LI></UL>
<P>The count includes Fixlets in the following content sites:</P>
<UL>
<LI>Patches for Windows 
<LI>Patches for RHEL8 
<LI>Patches for RHEL9 
<LI>Patches for RHEL10 
<LI>Patches for Ubuntu&nbsp;2204 
<LI>Patches for Ubuntu 2404 
<LI>Patches for Ubuntu 2604</LI></UL>
<P><FONT color=#ff0000 size=3><STRONG>Notes:</STRONG></FONT></P>
<UL>
<LI><STRONG>Not all OS vendors classify their patches using the same severity levels; therefore, the counts within each severity level are only valid if the vendor publishes patches with those specific severity levels.<BR></STRONG>
<LI><STRONG>There are two properties for Fixlets of "Unspecified" severity because different vendors use both "Unspecified" and "&lt;Unspecified&gt;" to classify their patches.<BR></STRONG>
<LI><STRONG>Any operating systems that are not supported will display a value of "<EM>O/S Not Supported by Property</EM>" in the value</STRONG></LI></UL>
<P>&nbsp;</P>]]></Description>
		<Relevance>(name of operating system as string starts with "Win") or ((name of operating system contains "Linux Red Hat") and (version of operating system as string starts with "8" or version of operating system as string starts with "9" or version of operating system as string starts with "10")) or ((name of operating system as string starts with "Linux Ubuntu") and (version of operating system as string starts with "22" or version of operating system as string starts with "24" or version of operating system as string starts with "26"))</Relevance>
		<Source>Internal</Source>
		<SourceReleaseDate>2026-04-29</SourceReleaseDate>
		<MIMEField>
			<Name>x-fixlet-modification-time</Name>
			<Value>Wed, 29 Apr 2026 20:00:00 +0000</Value>
		</MIMEField>
		<Domain>BESC</Domain>
		<Property Name="Critical Patches Outstanding" ID="1">if name of operating system contains "Win" then if exists site "http://sync.bigfix.com/cgi-bin/bfgather/bessecurity" then (number of relevant fixlets whose (value of header "x-fixlet-source-severity" of it as lowercase = "critical") of site "http://sync.bigfix.com/cgi-bin/bfgather/bessecurity") as string else "Not Subscribed to Windows Patches Site" else if name of operating system contains "Linux Red Hat" and version of operating system as string starts with "8" then if exists site "http://sync.bigfix.com/cgi-bin/bfgather/patchesforrhel8" then (number of relevant fixlets whose (value of header "x-fixlet-source-severity" of it as lowercase = "critical") of site "http://sync.bigfix.com/cgi-bin/bfgather/patchesforrhel8") as string else "Not Subscribed to Patch Site" else if name of operating system contains "Linux Red Hat" and version of operating system as string starts with "9" then if exists site "http://sync.bigfix.com/cgi-bin/bfgather/patchesforrhel9" then (number of relevant fixlets whose (value of header "x-fixlet-source-severity" of it as lowercase = "critical") of site "http://sync.bigfix.com/cgi-bin/bfgather/patchesforrhel9") as string else "Not Subscribed to Patch Site" else if name of operating system contains "Linux Red Hat" and version of operating system as string starts with "10" then if exists site "http://sync.bigfix.com/cgi-bin/bfgather/patchesforrhel10" then (number of relevant fixlets whose (value of header "x-fixlet-source-severity" of it as lowercase = "critical") of site "http://sync.bigfix.com/cgi-bin/bfgather/patchesforrhel10") as string else "Not Subscribed to Patch Site" else if name of operating system contains "Linux Ubuntu" and version of operating system as string starts with "22" then if exists site "http://sync.bigfix.com/cgi-bin/bfgather/patchesforubuntu2204" then (number of relevant fixlets whose (value of header "x-fixlet-source-severity" of it as lowercase = "critical") of site "http://sync.bigfix.com/cgi-bin/bfgather/patchesforubuntu2204") as string else "Not Subscribed to Patch Site" else if name of operating system contains "Linux Ubuntu" and version of operating system as string starts with "24" then if exists site "http://sync.bigfix.com/cgi-bin/bfgather/patchesforubuntu2404" then (number of relevant fixlets whose (value of header "x-fixlet-source-severity" of it as lowercase = "critical") of site "http://sync.bigfix.com/cgi-bin/bfgather/patchesforubuntu2404") as string else "Not Subscribed to Patch Site" else if name of operating system contains "Linux Ubuntu" and version of operating system as string starts with "26" then if exists site "http://sync.bigfix.com/cgi-bin/bfgather/patchesforubuntu2604" then (number of relevant fixlets whose (value of header "x-fixlet-source-severity" of it as lowercase = "critical") of site "http://sync.bigfix.com/cgi-bin/bfgather/patchesforubuntu2604") as string else "Not Subscribed to Patch Site" else "O/S Not Supported by Property"</Property>
